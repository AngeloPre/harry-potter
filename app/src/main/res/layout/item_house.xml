<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/houseCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/card_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="20dp">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:id="@+id/houseShield"
            android:background="@drawable/shield_gryffindor">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_shield" />
        </FrameLayout>

        <TextView
            android:id="@+id/houseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/gryffindor"
            android:textColor="@color/text_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/houseBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/badge_gryffindor"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="@string/gryffindor_trait"
            android:textColor="@color/badge_gryffindor_text"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
