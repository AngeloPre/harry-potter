<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_harrypotter"
    android:orientation="vertical"
    tools:context=".controller.EstudantePorCasa">

    <!-- Header -->
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/brand"
        android:scaleType="fitStart"
        android:src="@drawable/logo" />

    <!-- Titulo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="@string/houses_title"
        android:textColor="@color/card_surface"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="4dp"
        android:text="@string/houses_pick_subtitle"
        android:textColor="@color/text_light"
        android:textSize="15sp" />

    <!-- Filtro de casas (Radio Buttons 2x2) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbGryffindor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingVertical="10dp"
            android:text="@string/gryffindor"
            android:textColor="@color/gryffindor"
            android:textSize="15sp"
            android:textStyle="bold"
            android:buttonTint="@color/gryffindor" />

        <RadioButton
            android:id="@+id/rbSlytherin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingVertical="10dp"
            android:text="@string/slytherin"
            android:textColor="@color/slytherin"
            android:textSize="15sp"
            android:textStyle="bold"
            android:buttonTint="@color/slytherin" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/rbRavenclaw"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingVertical="10dp"
            android:text="@string/ravenclaw"
            android:textColor="@color/ravenclaw"
            android:textSize="15sp"
            android:textStyle="bold"
            android:buttonTint="@color/ravenclaw" />

        <RadioButton
            android:id="@+id/rbHufflepuff"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingVertical="10dp"
            android:text="@string/hufflepuff"
            android:textColor="@color/hufflepuff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:buttonTint="@color/hufflepuff" />
    </LinearLayout>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        tools:itemCount="4"
        tools:listitem="@layout/recycler_view_student" />

    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp" />
</LinearLayout>
